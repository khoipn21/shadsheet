          Spreadsheet Demo ({ROW_COUNT.toLocaleString()} rows × {COL_COUNT} cols)
        </h1>
      </div>

      <SpreadsheetProvider data={data} columns={columns}>
        <div className="flex items-center gap-2 mb-1">
          <GlobalSearchFilter />
        </div>
        <SpreadsheetGrid className="flex-1 min-h-0" />
      </SpreadsheetProvider>
    </div>
  );
}
