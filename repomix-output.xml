import { memo } from "react";
import type { Cell } from "@tanstack/react-table";
import type { CellValue } from "@/types/spreadsheet-types";

interface CellRendererProps {
  cell: Cell<Record<string, CellValue>, unknown>;
  width: number;
  height: number;
  translateX: number;
}

/** Display-only cell — editing added in Phase 4 */
export const CellRenderer = memo(function CellRenderer({
  cell,
  width,
  height,
  translateX,
}: CellRendererProps) {
  const value = cell.getValue();
  const displayValue = value == null ? "" : String(value);

  return (
    <div
      role="gridcell"
      data-col-id={cell.column.id}
      className="absolute top-0 left-0 flex items-center border-r border-b border-border px-2 overflow-hidden text-ellipsis whitespace-nowrap text-sm"
      style={{
        width,
        height,
        transform: `translateX(${translateX}px)`,
      }}
    >
      {displayValue}
    </div>
  );
});
