{
  "name": "@shadsheet/ui",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "Headless React spreadsheet component library built with TanStack Table, HyperFormula, and shadcn conventions",
  "keywords": [
    "react",
    "spreadsheet",
    "headless",
    "shadcn",
    "tanstack-table",
    "data-grid",
    "hyperformula",
    "virtualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shadsheet/ui.git"
  },
  "homepage": "https://shadsheet.dev",
  "bugs": {
    "url": "https://github.com/shadsheet/ui/issues"
  },
  "files": [
    "dist",
    "registry.json"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^1.0.0",
    "@base-ui/react": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": { "optional": true },
    "@base-ui/react": { "optional": true }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hyperformula": "^3.2.0",
    "immer": "^10.1.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@eslint/js": "^9.22.0",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.0.14",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.0.14",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.3.1"
  }
}
